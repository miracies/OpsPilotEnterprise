# OpsPilot Enterprise - Environment Configuration Example
# Copy this file to .env and fill in your values

# ── LLM Configuration ───────────────────────────────────────
# Supports any OpenAI-compatible API (Zhipu AI, OpenAI, etc.)
LLM_ENABLED=true
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-api-key-here
LLM_MODEL=glm-5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Service URLs ─────────────────────────────────────────────
ORCHESTRATOR_URL=http://127.0.0.1:8010
TOOL_GATEWAY_URL=http://127.0.0.1:8020
CHANGE_IMPACT_SERVICE_URL=http://127.0.0.1:8040
EVENT_INGESTION_URL=http://127.0.0.1:8060
RESOURCE_BFF_URL=http://127.0.0.1:8000
VMWARE_GATEWAY_URL=http://127.0.0.1:8030
KUBERNETES_GATEWAY_URL=http://127.0.0.1:8080
MEMORY_SERVICE_URL=http://127.0.0.1:8073
LOG_GATEWAY_URL=http://127.0.0.1:8055
MEMORY_POSTGRES_DSN=postgresql://opspilot:opspilot@127.0.0.1:5432/opspilot
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=opspilot-memory

# ── Secret Store ─────────────────────────────────────────────
OPSPILOT_SECRET_KEY=change-me-for-production
OPSPILOT_SECRET_DB=data/secrets.db

# ── Real Monitoring Fallbacks ────────────────────────────────
VMWARE_USE_MOCK_FALLBACK=false
K8S_USE_MOCK_FALLBACK=false
K8S_KUBECONFIG_PATH=C:\Users\mirac\.kube\config
VCENTER_ENDPOINT=
VCENTER_USERNAME=shaoyong.chen@vsphere.local
VCENTER_PASSWORD=
VCENTER_POWERED_OFF_VM_INCIDENT_MODE=expected_only
VCENTER_EXPECTED_RUNNING_VM_PATTERNS=
K8S_API_SERVER=
K8S_TOKEN=
K8S_NAMESPACE=

# Unified log platform (optional; first-class backend is OpenSearch)
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=OpsPilot-OpenSearch-2026!
OPENSEARCH_TLS_VERIFY=false
OPENSEARCH_WEB_URL=http://192.168.51.169:5601/app/discover
OPENSEARCH_INDEX_PATTERN=opspilot-vmware-*
OPENSEARCH_DASHBOARDS_ANONYMOUS_AUTH_ENABLED=true
LOG_PLATFORM_URL=
LOG_GATEWAY_DB=data/log_gateway.db

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY_SECONDS=86400
