# ──────────────────────────────────────────────
# OpsPilot Enterprise - Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── General ──
NODE_ENV=development
LOG_LEVEL=debug

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── API BFF ──
BFF_PORT=8000
ORCHESTRATOR_URL=http://localhost:8010
TOOL_GATEWAY_URL=http://localhost:8020
EVENT_INGESTION_URL=http://localhost:8060

# ── LangGraph Orchestrator ──
ORCHESTRATOR_PORT=8010
TOOL_GATEWAY_URL=http://localhost:8020
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=sk-placeholder
LLM_MODEL=gpt-4o

# ── Tool Gateway ──
TOOL_GATEWAY_PORT=8020
OPA_URL=http://localhost:8181
VMWARE_GATEWAY_URL=http://localhost:8030
CHANGE_IMPACT_URL=http://localhost:8040
EVIDENCE_AGGREGATOR_URL=http://localhost:8050

# ── VMware Skill Gateway (mock) ──
VMWARE_GATEWAY_PORT=8030

# ── Change Impact Service ──
CHANGE_IMPACT_PORT=8040

# ── Evidence Aggregator ──
EVIDENCE_AGGREGATOR_PORT=8050

# ── Event Ingestion Service ──
EVENT_INGESTION_PORT=8060

# ── Database (reserved for later) ──
DATABASE_URL=postgresql://opspilot:opspilot@localhost:5432/opspilot
REDIS_URL=redis://localhost:6379/0

# ── OPA (reserved) ──
OPA_BUNDLE_URL=

# ── n8n (reserved) ──
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
